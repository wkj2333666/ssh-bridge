{
  "version": 1,
  "ssh": {
    "binary": "ssh",
    "config_file": "~/.ssh/config",
    "connect_timeout_sec": 10,
    "server_alive_interval_sec": 15,
    "server_alive_count_max": 3
  },
  "limits": {
    "command_timeout_sec": 120,
    "max_command_timeout_sec": 1800,
    "max_output_bytes": 1048576,
    "max_file_bytes": 1048576
  },
  "hosts": {
    "devbox": {
      "root": "/srv/my-project",
      "read_only": false,
      "description": "Primary development server"
    },
    "production-readonly": {
      "root": "/srv/app",
      "read_only": true,
      "description": "File inspection and connectivity checks only"
    }
  }
}
