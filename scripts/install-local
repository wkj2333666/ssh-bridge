#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import shutil
import subprocess
import sys
from pathlib import Path


PLUGIN_ROOT = Path(__file__).resolve().parent.parent
SERVER = PLUGIN_ROOT / "mcp" / "server.py"
SKILL = PLUGIN_ROOT / "skills" / "remote-ssh-ops"
SKILL_LINK = Path.home() / ".agents" / "skills" / "remote-ssh-ops"


def codex_binary() -> str:
    binary = shutil.which("codex")
    if binary is None:
        raise RuntimeError("codex was not found on PATH")
    return binary


def existing_mcp() -> dict[str, object] | None:
    completed = subprocess.run(
        [codex_binary(), "mcp", "get", "ssh-bridge", "--json"],
        text=True,
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        return None
    try:
        value = json.loads(completed.stdout)
    except json.JSONDecodeError as exc:
        raise RuntimeError("could not parse `codex mcp get ssh-bridge --json`") from exc
    if not isinstance(value, dict):
        raise RuntimeError("unexpected Codex MCP configuration response")
    return value


def mcp_matches(value: dict[str, object]) -> bool:
    transport = value.get("transport")
    if not isinstance(transport, dict):
        return False
    return (
        transport.get("type") == "stdio"
        and transport.get("command") == "python3"
        and transport.get("args") == [str(SERVER)]
    )


def install(*, apply: bool) -> dict[str, object]:
    existing = existing_mcp()
    if existing is not None and not mcp_matches(existing):
        raise RuntimeError(
            "an MCP server named 'ssh-bridge' already has a different configuration; "
            "inspect it with `codex mcp get ssh-bridge --json` and resolve it manually"
        )
    if SKILL_LINK.exists() or SKILL_LINK.is_symlink():
        if not SKILL_LINK.is_symlink() or SKILL_LINK.resolve() != SKILL.resolve():
            raise RuntimeError(
                f"skill destination already exists and is not this checkout: {SKILL_LINK}"
            )

    actions: list[str] = []
    if existing is None:
        actions.append(f"register MCP ssh-bridge -> python3 {SERVER}")
        if apply:
            completed = subprocess.run(
                [codex_binary(), "mcp", "add", "ssh-bridge", "--", "python3", str(SERVER)],
                check=False,
            )
            if completed.returncode != 0:
                raise RuntimeError(f"`codex mcp add` failed with exit {completed.returncode}")
    else:
        actions.append("MCP ssh-bridge already matches")

    if not SKILL_LINK.is_symlink():
        actions.append(f"symlink {SKILL_LINK} -> {SKILL}")
        if apply:
            SKILL_LINK.parent.mkdir(parents=True, exist_ok=True)
            SKILL_LINK.symlink_to(SKILL, target_is_directory=True)
    else:
        actions.append("remote-ssh-ops skill symlink already matches")

    return {
        "applied": apply,
        "actions": actions,
        "next": (
            "Restart Codex or start a new task, then run `codex mcp list` and invoke "
            "`$remote-ssh-ops`."
        ),
        "approval_recommendation": (
            "Set mcp_servers.ssh-bridge.default_tools_approval_mode to 'writes' in config.toml."
        ),
    }


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Safely register the local MCP server and user Skill symlink."
    )
    parser.add_argument(
        "--apply",
        action="store_true",
        help="Perform changes; without this flag only print the planned actions.",
    )
    args = parser.parse_args()
    try:
        print(json.dumps(install(apply=args.apply), ensure_ascii=False, indent=2))
        return 0
    except (OSError, RuntimeError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
